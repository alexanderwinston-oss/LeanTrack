{
  "expo": {
    "name": "LeanTrack",
    "slug": "leantrack",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.alexander.leantrack",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "updates": {
      "url": "https://u.expo.dev/7be8528a-7b26-4359-8927-6c5a4067eca1",
      "fallbackToCacheTimeout": 30000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "7be8528a-7b26-4359-8927-6c5a4067eca1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#10b981"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Autoriser l acc\u00e8s \u00e0 la cam\u00e9ra pour analyser vos repas."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Autoriser l acc\u00e8s \u00e0 vos photos.",
          "savePhotosPermission": "Autoriser l enregistrement de vos photos de repas dans la galerie.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}