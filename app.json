{
  "expo": {
    "name": "LeanTrack",
    "slug": "leantrack",
    "version": "1.0.0",
    "icon": "./assets/images/icon.png",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.alexander.leantrack",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "updates": {
      "url": "https://u.expo.dev/7be8528a-7b26-4359-8927-6c5a4067eca1",
      "fallbackToCacheTimeout": 30000
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "7be8528a-7b26-4359-8927-6c5a4067eca1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-notifications",
        {
          "color": "#10b981"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Autoriser l accès à la caméra pour analyser vos repas."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Autoriser l accès à vos photos.",
          "savePhotosPermission": "Autoriser l enregistrement de vos photos de repas dans la galerie.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "react-native-health-connect",
      "./plugins/withHealthConnect",
      "./plugins/withMainActivityHealthConnect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ]
  }
}
